{
  "name": "Odometria Visual ARM64",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "odometria-visual",
  "workspaceFolder": "/work",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}